@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["DevTools_Title"];
    bool seedEnabled = ViewData["SeedEnabled"] as bool? ?? false;
    bool allowReset = ViewData["AllowReset"] as bool? ?? false;
    string environmentName = ViewData["EnvironmentName"]?.ToString() ?? "Development";
    string demoEmail = ViewData["DemoEmail"]?.ToString() ?? "demo@student.com";
    string demoPassword = ViewData["DemoPassword"]?.ToString() ?? "Demo@123456";
}

<div class="page-header">
    <p class="page-subtitle mb-1">@Localizer["DevTools_Environment"]: <strong>@environmentName</strong></p>
    <h1 class="page-title">@Localizer["DevTools_Title"]</h1>
    <p class="page-subtitle">@Localizer["DevTools_Description"]</p>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="section-card">
            <h2 class="h5 mb-3">@Localizer["DevTools_ResetDemoData"]</h2>
            <div class="alert alert-warning mb-4">
                @Localizer["DevTools_Warning"]
            </div>

            <dl class="row mb-4">
                <dt class="col-sm-4">@Localizer["DevTools_SeedEnabled"]</dt>
                <dd class="col-sm-8">
                    <span class="badge @(seedEnabled ? "bg-success" : "bg-secondary")">@seedEnabled</span>
                </dd>
                <dt class="col-sm-4">@Localizer["DevTools_AllowReset"]</dt>
                <dd class="col-sm-8">
                    <span class="badge @(allowReset ? "bg-success" : "bg-secondary")">@allowReset</span>
                </dd>
            </dl>

            <form asp-action="ResetDemoData" method="post"
                  data-confirm-delete
                  data-confirm-message="@Localizer["DevTools_ResetConfirm"]">
                <button type="submit" class="btn btn-danger" @(seedEnabled && allowReset ? null : "disabled")>
                    @Localizer["DevTools_ResetDemoData"]
                </button>
                <a class="btn btn-outline-secondary ms-2" asp-controller="Dashboard" asp-action="Index">@Localizer["Back to Dashboard"]</a>
            </form>

            @if (!seedEnabled || !allowReset)
            {
                <p class="text-muted mt-3 mb-0">@Localizer["DevTools_ResetDisabled"]</p>
            }
        </div>
    </div>

    <div class="col-lg-5">
        <div class="section-card">
            <h2 class="h5 mb-3">@Localizer["DevTools_DemoAccount"]</h2>
            <p class="mb-2"><strong>Email:</strong> @demoEmail</p>
            <p class="mb-0"><strong>Password:</strong> @demoPassword</p>
        </div>
    </div>
</div>
