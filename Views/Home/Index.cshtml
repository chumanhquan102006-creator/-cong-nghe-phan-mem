@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = "Home";
}

<section class="py-4">
    <div class="hero-section mb-4">
        <div class="row align-items-center g-4">
            <div class="col-lg-8">
                <h1 class="display-5 fw-bold mb-3">Academic AI Assistant</h1>
                <p class="lead text-muted mb-4">@Localizer["Academic AI Assistant Home Description"]</p>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-primary btn-lg" asp-controller="Dashboard" asp-action="Index">@Localizer["Get Started"]</a>
                    <a class="btn btn-outline-primary btn-lg" asp-controller="Documents" asp-action="Index">@Localizer["View Documents"]</a>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="section-card">
                    <h2 class="h5">@Localizer["Demo-ready modules"]</h2>
                    <p class="text-muted mb-0">@Localizer["Demo-ready modules description"]</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6 col-lg-3">
            <div class="feature-card h-100">
                <h2 class="h5">@Localizer["PDF Reading Assistant"]</h2>
                <p class="text-muted mb-0">@Localizer["PDF Reading Assistant description"]</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="feature-card h-100">
                <h2 class="h5">@Localizer["Writing Feedback Studio"]</h2>
                <p class="text-muted mb-0">@Localizer["Writing Feedback Studio description"]</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="feature-card h-100">
                <h2 class="h5">@Localizer["Citation & Similarity Checker"]</h2>
                <p class="text-muted mb-0">@Localizer["Citation & Similarity Checker description"]</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="feature-card h-100">
                <h2 class="h5">@Localizer["Knowledge Graph"]</h2>
                <p class="text-muted mb-0">@Localizer["Knowledge Graph description"]</p>
            </div>
        </div>
    </div>
</section>
