@model AcademicAIAssistant.Models.ViewModels.DocumentChatViewModel
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["Chat with PDF"];
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Localizer["Chat with PDF"]</h1>
            <p class="page-subtitle">@Model.Document.Title</p>
        </div>
        <a class="btn btn-outline-secondary" asp-controller="Documents" asp-action="Details" asp-route-id="@Model.Document.Id" asp-route-tab="chat">@Localizer["BackToWorkspace"]</a>
    </div>

    <partial name="_ChatPanel" model="Model" />
</section>
