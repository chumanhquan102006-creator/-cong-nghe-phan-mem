@model AcademicAIAssistant.Models.OCRScan
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["OCR Details"];
    bool fileExists = ViewData["FileExists"] as bool? ?? false;
    bool hasText = !string.IsNullOrWhiteSpace(Model.ExtractedText);
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Model.Title</h1>
            <p class="page-subtitle">@Localizer["OCR Details subtitle"]</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="History">@Localizer["Back to OCR History"]</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="section-card">
                <h2 class="h5">@Localizer["Image Information"]</h2>
                <dl class="row mb-3">
                    <dt class="col-sm-5">@Localizer["Original File"]</dt>
                    <dd class="col-sm-7">@Model.OriginalFileName</dd>

                    <dt class="col-sm-5">@Localizer["Language"]</dt>
                    <dd class="col-sm-7">@(Model.Language == "vie" ? Localizer["Vietnamese"] : Localizer["English"])</dd>

                    <dt class="col-sm-5">@Localizer["File Size"]</dt>
                    <dd class="col-sm-7">@((Model.FileSize / 1024.0).ToString("0.0")) KB</dd>

                    <dt class="col-sm-5">@Localizer["Created"]</dt>
                    <dd class="col-sm-7">@Model.CreatedAt.ToDisplayDateTime()</dd>
                </dl>

                @if (fileExists)
                {
                    <img src="@Model.FilePath" class="img-fluid rounded border" alt="@Model.Title" />
                }
                else
                {
                    <div class="alert alert-warning mb-0">@Localizer["OCR Missing Image"]</div>
                }
            </div>
        </div>

        <div class="col-lg-7">
            <div class="section-card">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                    <h2 class="h5 mb-0">@Localizer["Extracted Text"]</h2>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-outline-primary btn-sm"
                                data-copy-target="ocrText"
                                data-copied-text="@Localizer["Copied"]"
                                data-copy-error-text="@Localizer["CopyFailed"]"
                                @(hasText ? "" : "disabled")>
                            @Localizer["Copy"]
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                data-export-target="ocrText"
                                data-export-filename="ocr-result"
                                data-export-success-text="@Localizer["ExportedTxt"]"
                                data-export-error-text="@Localizer["ExportFailed"]"
                                aria-label="@Localizer["DownloadTxt"]"
                                @(hasText ? "" : "disabled")>
                            @Localizer["ExportTxt"]
                        </button>
                        @if (hasText)
                        {
                            <a class="btn btn-primary btn-sm"
                               asp-controller="Writing"
                               asp-action="Index"
                               asp-route-prefillFromOcrId="@Model.Id">@Localizer["Send to Writing Studio"]</a>
                            <a class="btn btn-outline-warning btn-sm"
                               asp-controller="TextScan"
                               asp-action="Index"
                               asp-route-prefillFromOcrId="@Model.Id">@Localizer["Run Text Scan"]</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary btn-sm" disabled>@Localizer["Send to Writing Studio"]</button>
                            <button type="button" class="btn btn-outline-warning btn-sm" disabled>@Localizer["Run Text Scan"]</button>
                        }
                    </div>
                </div>

                @if (hasText)
                {
                    <textarea id="ocrText" class="form-control text-preview" rows="18" readonly>@Model.ExtractedText</textarea>
                }
                else
                {
                    <div class="empty-state text-start">
                        <p class="fw-semibold mb-2">@Localizer["OCRNoTextTitle"]</p>
                        <p class="mb-2">@Localizer["OCRNoTextMessage"]</p>
                        <ul class="mb-3">
                            <li>@Localizer["OCRNoTextTipLanguage"]</li>
                            <li>@Localizer["OCRNoTextTipQuality"]</li>
                            <li>@Localizer["OCRNoTextTipBlur"]</li>
                            <li>@Localizer["OCRNoTextTipContrast"]</li>
                        </ul>
                        <a class="btn btn-outline-primary btn-sm" asp-action="Index">@Localizer["ChooseAnotherImage"]</a>
                    </div>
                    <textarea id="ocrText" class="d-none"></textarea>
                }
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <a class="btn btn-outline-secondary" asp-action="History">@Localizer["Back to OCR History"]</a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      class="js-confirm-form"
                      data-confirm-delete
                      data-confirm-message="@Localizer["ConfirmDeleteMessage"]">
                    <button type="submit" class="btn btn-danger">@Localizer["Delete"]</button>
                </form>
            </div>
        </div>
    </div>
</section>
