@model AcademicAIAssistant.Models.OCRScan

@{
    ViewData["Title"] = "OCR Details";
    bool fileExists = ViewData["FileExists"] as bool? ?? false;
    bool hasText = !string.IsNullOrWhiteSpace(Model.ExtractedText);
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Model.Title</h1>
            <p class="page-subtitle">OCR scan details and extracted text.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="History">Back to OCR History</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="section-card">
                <h2 class="h5">Image Information</h2>
                <dl class="row mb-3">
                    <dt class="col-sm-5">Original file</dt>
                    <dd class="col-sm-7">@Model.OriginalFileName</dd>

                    <dt class="col-sm-5">Language</dt>
                    <dd class="col-sm-7">@(Model.Language == "vie" ? "Vietnamese" : "English")</dd>

                    <dt class="col-sm-5">File size</dt>
                    <dd class="col-sm-7">@((Model.FileSize / 1024.0).ToString("0.0")) KB</dd>

                    <dt class="col-sm-5">Created</dt>
                    <dd class="col-sm-7">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                </dl>

                @if (fileExists)
                {
                    <img src="@Model.FilePath" class="img-fluid rounded border" alt="@Model.Title" />
                }
                else
                {
                    <div class="alert alert-warning mb-0">The image file is missing from the server.</div>
                }
            </div>
        </div>

        <div class="col-lg-7">
            <div class="section-card">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                    <h2 class="h5 mb-0">Extracted Text</h2>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" id="copyTextButton" class="btn btn-outline-primary btn-sm" @(hasText ? "" : "disabled")>Copy Text</button>
                        <a class="btn btn-primary btn-sm @(hasText ? "" : "disabled")"
                           asp-controller="Writing"
                           asp-action="Index"
                           asp-route-prefillFromOcrId="@Model.Id">Send to Writing Studio</a>
                        <a class="btn btn-outline-warning btn-sm @(hasText ? "" : "disabled")"
                           asp-controller="TextScan"
                           asp-action="Index"
                           asp-route-prefillFromOcrId="@Model.Id">Run Text Scan</a>
                    </div>
                </div>

                @if (hasText)
                {
                    <textarea id="ocrText" class="form-control text-preview" rows="18" readonly>@Model.ExtractedText</textarea>
                }
                else
                {
                    <div class="empty-state">
                        <p>No readable text was detected.</p>
                    </div>
                    <textarea id="ocrText" class="d-none"></textarea>
                }
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <a class="btn btn-outline-secondary" asp-action="History">Back to OCR History</a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Delete this OCR scan?');">
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        const copyButton = document.getElementById('copyTextButton');
        const textArea = document.getElementById('ocrText');

        if (copyButton && textArea) {
            copyButton.addEventListener('click', async () => {
                const text = textArea.value;
                if (!text.trim()) {
                    alert('No text available to copy.');
                    return;
                }

                await navigator.clipboard.writeText(text);
                copyButton.textContent = 'Copied';
                setTimeout(() => copyButton.textContent = 'Copy Text', 1500);
            });
        }
    </script>
}
