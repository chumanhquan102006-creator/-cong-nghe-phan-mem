@model AcademicAIAssistant.Models.ViewModels.OCRUploadViewModel
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["OCR Scanner"];
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Localizer["OCR Scanner"]</h1>
            <p class="page-subtitle">@Localizer["OCR Scanner subtitle"]</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="History">@Localizer["OCR History"]</a>
    </div>

    <div class="section-card">
        <form asp-action="Upload" method="post" enctype="multipart/form-data" class="js-loading-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-3">
                <div class="col-md-7">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" placeholder="@Localizer["OCR Title Placeholder"]" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-5">
                    <label asp-for="Language" class="form-label"></label>
                    <select asp-for="Language" class="form-select">
                        @foreach (var option in OCRUploadViewModel.LanguageOptions)
                        {
                            <option value="@option.Key">@option.Value</option>
                        }
                    </select>
                    <span asp-validation-for="Language" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="ImageFile" class="form-label"></label>
                    <input asp-for="ImageFile" class="form-control" type="file" accept=".jpg,.jpeg,.png,image/jpeg,image/png" />
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                    <div class="form-text">@Localizer["Upload_ImageHint"]</div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary mt-3" data-loading-text="@Localizer["Scanning"]">@Localizer["Scan Image"]</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
