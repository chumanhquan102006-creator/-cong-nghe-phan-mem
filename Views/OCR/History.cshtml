@model List<AcademicAIAssistant.Models.OCRScan>

@{
    ViewData["Title"] = "OCR History";
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">OCR History</h1>
            <p class="page-subtitle">Review images you scanned and reuse extracted text.</p>
        </div>
        <a class="btn btn-primary" asp-action="Index">Scan New Image</a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <h2 class="h5">No OCR scans yet.</h2>
            <p>Upload an image to extract text.</p>
            <a class="btn btn-primary" asp-action="Index">Upload Image</a>
        </div>
    }
    else
    {
        <div class="section-card">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>File</th>
                            <th>Language</th>
                            <th>Text Length</th>
                            <th>Created</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var scan in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@scan.Title</td>
                                <td>@scan.OriginalFileName</td>
                                <td>@(scan.Language == "vie" ? "Vietnamese" : "English")</td>
                                <td>@scan.ExtractedText.Length chars</td>
                                <td>@scan.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@scan.Id">View Details</a>
                                    <form asp-action="Delete" asp-route-id="@scan.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this OCR scan?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
