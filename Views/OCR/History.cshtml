@model List<AcademicAIAssistant.Models.OCRScan>
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["OCR History"];
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Localizer["OCR History"]</h1>
            <p class="page-subtitle">@Localizer["OCR History subtitle"]</p>
        </div>
        <a class="btn btn-primary" asp-action="Index">@Localizer["StartOcrScan"]</a>
    </div>

    @if (!Model.Any())
    {
        <partial name="_EmptyState" view-data='new ViewDataDictionary(ViewData)
        {
            ["IconClass"] = "bi bi-card-image",
            ["Title"] = Localizer["EmptyOcrTitle"],
            ["Description"] = Localizer["EmptyOcrDescription"],
            ["ActionText"] = Localizer["StartOcrScan"],
            ["ActionController"] = "OCR",
            ["ActionAction"] = "Index"
        }' />
    }
    else
    {
        <div class="section-card">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>@Localizer["Title"]</th>
                            <th>@Localizer["File"]</th>
                            <th>@Localizer["Language"]</th>
                            <th>@Localizer["Text Length"]</th>
                            <th>@Localizer["Created"]</th>
                            <th class="text-end">@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var scan in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@scan.Title</td>
                                <td>@scan.OriginalFileName</td>
                                <td>@(scan.Language == "vie" ? Localizer["Vietnamese"] : Localizer["English"])</td>
                                <td>@scan.ExtractedText.Length @Localizer["Characters"]</td>
                                <td>@scan.CreatedAt.ToDisplayDateTime()</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@scan.Id">@Localizer["View Details"]</a>
                                    <form asp-action="Delete" asp-route-id="@scan.Id" method="post"
                                          class="d-inline js-confirm-form"
                                          data-confirm-message="@Localizer["ConfirmDeleteMessage"]">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@Localizer["Delete"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
