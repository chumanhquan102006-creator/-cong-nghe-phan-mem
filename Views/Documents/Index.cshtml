@model IEnumerable<AcademicAIAssistant.Models.Document>
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = "Documents";
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Localizer["Document Library"]</h1>
            <p class="page-subtitle">@Localizer["Document Library subtitle"]</p>
        </div>
        <a class="btn btn-primary" asp-controller="Documents" asp-action="Upload">@Localizer["Upload New PDF"]</a>
    </div>

    @if (!Model.Any())
    {
        <partial name="_EmptyState" view-data='new ViewDataDictionary(ViewData)
        {
            ["IconClass"] = "bi bi-file-earmark-pdf",
            ["Title"] = Localizer["EmptyDocumentsTitle"],
            ["Description"] = Localizer["EmptyDocumentsDescription"],
            ["ActionText"] = Localizer["UploadFirstPdf"],
            ["ActionController"] = "Documents",
            ["ActionAction"] = "Upload"
        }' />
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle section-card">
                <thead class="table-light">
                    <tr>
                        <th>@Localizer["Title"]</th>
                        <th>@Localizer["Original File"]</th>
                        <th>@Localizer["File Size"]</th>
                        <th>@Localizer["Uploaded At"]</th>
                        <th>@Localizer["Status"]</th>
                        <th>@Localizer["Summary"]</th>
                        <th class="text-end">@Localizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var document in Model)
                    {
                        <tr>
                            <td>@document.Title</td>
                            <td>@document.OriginalFileName</td>
                            <td>@((document.FileSize / 1024.0 / 1024.0).ToString("0.00")) MB</td>
                            <td>@document.UploadedAt.ToDisplayDateTime()</td>
                            <td>
                                @if (document.SummaryGeneratedAt.HasValue)
                                {
                                    <span class="badge text-bg-success status-badge">@Localizer["Summarized"]</span>
                                }
                                else if (document.ExtractedAt.HasValue)
                                {
                                    <span class="badge text-bg-primary status-badge">@Localizer["Extracted"]</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary status-badge">@Localizer["Uploaded"]</span>
                                }
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(document.Summary) ? Localizer["No summary yet."].Value : document.Summary)</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@document.Id">@Localizer["View Details"]</a>
                                <form asp-action="Delete" asp-route-id="@document.Id" method="post"
                                      class="d-inline js-confirm-form"
                                      data-confirm-delete
                                      data-confirm-message="@Localizer["ConfirmDeleteMessage"]">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">@Localizer["Delete"]</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
