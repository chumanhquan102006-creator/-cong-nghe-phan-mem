@model AcademicAIAssistant.Models.ViewModels.DocumentWorkspaceViewModel
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["DocumentWorkspace"];
    var document = Model.Document;
    bool hasText = Model.HasExtractedText;
    bool hasSummary = Model.HasSummary;
    bool fileExists = Model.FileExists;

    string pageCount = document.PageCount > 0
        ? Localizer[document.PageCount == 1 ? "PageCountSingular" : "PageCountPlural", document.PageCount].Value
        : Localizer["NotExtracted"].Value;
    string wordCount = document.WordCount > 0
        ? Localizer[document.WordCount == 1 ? "WordCountSingular" : "WordCountPlural", document.WordCount].Value
        : Localizer["NotExtracted"].Value;

    var chatModel = new DocumentChatViewModel
    {
        Document = document,
        Messages = Model.Messages,
        ReturnTo = "workspace"
    };
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Localizer["DocumentWorkspace"]</h1>
            <p class="page-subtitle">@Localizer["DocumentWorkspaceSubtitle"]</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Index">@Localizer["Back to Documents"]</a>
    </div>

    <div class="document-workspace-header section-card">
        <div class="document-workspace-header-main">
            <div class="document-file-icon" aria-hidden="true">
                <i class="bi bi-file-earmark-pdf"></i>
            </div>
            <div class="min-w-0">
                <h2 class="document-title">@document.Title</h2>
                <p class="document-filename">@document.OriginalFileName</p>
                <div class="document-meta">
                    <span>@pageCount</span>
                    <span>@wordCount</span>
                    <span>@Localizer["UploadedAtValue", document.UploadedAt.ToDisplayDateTime()]</span>
                </div>
            </div>
        </div>

        <div class="document-workspace-status" aria-label="@Localizer["ProcessingStatus"]">
            <span class="status-step status-step-complete">
                <i class="bi bi-check-circle-fill" aria-hidden="true"></i>
                @Localizer["Uploaded"]
            </span>
            <span class="status-step @(hasText ? "status-step-complete" : "status-step-pending")">
                <i class="bi @(hasText ? "bi-check-circle-fill" : "bi-circle")" aria-hidden="true"></i>
                @(hasText ? Localizer["TextReady"] : Localizer["NeedsTextExtraction"])
            </span>
            <span class="status-step @(hasSummary ? "status-step-complete" : "status-step-pending")">
                <i class="bi @(hasSummary ? "bi-check-circle-fill" : "bi-circle")" aria-hidden="true"></i>
                @(hasSummary ? Localizer["SummaryReady"] : Localizer["NoSummaryYet"])
            </span>
        </div>

        @if (!fileExists)
        {
            <div class="alert alert-warning mb-0">
                @Localizer["Documents_PdfMissingOnServer"]
            </div>
        }

        <div class="document-workspace-actions">
            @if (!hasText)
            {
                <form asp-action="ExtractText" asp-route-id="@document.Id" method="post" class="js-loading-form">
                    <button type="submit" class="btn btn-primary" data-loading-text="@Localizer["Processing"]" @(fileExists ? "" : "disabled")>@Localizer["Extract Text"]</button>
                </form>
            }
            else if (!hasSummary)
            {
                <form asp-action="GenerateSummary" asp-route-id="@document.Id" method="post" class="js-loading-form">
                    <button type="submit" class="btn btn-primary" data-loading-text="@Localizer["Generating"]">@Localizer["Generate Summary"]</button>
                </form>
                <a class="btn btn-outline-primary" asp-action="Details" asp-route-id="@document.Id" asp-route-tab="chat">@Localizer["AskAI"]</a>
            }
            else
            {
                <a class="btn btn-primary" asp-action="Details" asp-route-id="@document.Id" asp-route-tab="chat">@Localizer["AskAI"]</a>
                <form asp-action="GenerateSummary" asp-route-id="@document.Id" method="post" class="js-loading-form">
                    <button type="submit" class="btn btn-outline-primary" data-loading-text="@Localizer["Generating"]">@Localizer["RegenerateSummary"]</button>
                </form>
            }

            @if (fileExists)
            {
                <a class="btn btn-outline-secondary" href="@document.FilePath" target="_blank" rel="noopener">@Localizer["Open PDF"]</a>
            }

            <div class="dropdown">
                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    @Localizer["MoreActions"]
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                        <form asp-action="Delete" asp-route-id="@document.Id" method="post"
                              class="js-confirm-form"
                              data-confirm-delete
                              data-confirm-message="@Localizer["ConfirmDeleteMessage"]">
                            <button type="submit" class="dropdown-item text-danger">@Localizer["Delete"]</button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <nav class="document-workspace-tabs" aria-label="@Localizer["DocumentWorkspaceTabs"]">
        <a class="document-workspace-tab @(Model.IsOverviewActive ? "active" : "")"
           asp-action="Details"
           asp-route-id="@document.Id"
           asp-route-tab="overview"
           aria-current="@(Model.IsOverviewActive ? "page" : null)">@Localizer["Overview"]</a>
        <a class="document-workspace-tab @(Model.IsSummaryActive ? "active" : "")"
           asp-action="Details"
           asp-route-id="@document.Id"
           asp-route-tab="summary"
           aria-current="@(Model.IsSummaryActive ? "page" : null)">@Localizer["Summary"]</a>
        <a class="document-workspace-tab @(Model.IsChatActive ? "active" : "")"
           asp-action="Details"
           asp-route-id="@document.Id"
           asp-route-tab="chat"
           aria-current="@(Model.IsChatActive ? "page" : null)">@Localizer["AskAI"]</a>
    </nav>

    @if (Model.IsOverviewActive)
    {
        <div class="document-workspace-grid">
            <div class="section-card">
                <h2 class="h5">@Localizer["AboutThisDocument"]</h2>
                <dl class="document-facts mb-0">
                    <dt>@Localizer["Original File"]</dt>
                    <dd>@document.OriginalFileName</dd>
                    <dt>@Localizer["Pages"]</dt>
                    <dd>@pageCount</dd>
                    <dt>@Localizer["Words"]</dt>
                    <dd>@wordCount</dd>
                    <dt>@Localizer["Uploaded At"]</dt>
                    <dd>@document.UploadedAt.ToDisplayDateTime()</dd>
                </dl>
            </div>

            <div class="section-card">
                <h2 class="h5">
                    @if (!hasText)
                    {
                        @Localizer["NeedsProcessing"]
                    }
                    else if (!hasSummary)
                    {
                        @Localizer["ReadyToExplore"]
                    }
                    else
                    {
                        @Localizer["ReadyToUse"]
                    }
                </h2>
                <ul class="capability-list mb-0">
                    @if (!hasText)
                    {
                        <li><i class="bi bi-arrow-right-circle" aria-hidden="true"></i><span>@Localizer["CapabilityExtractText"]</span></li>
                        <li><i class="bi bi-lock" aria-hidden="true"></i><span>@Localizer["CapabilitySummaryAfterText"]</span></li>
                        <li><i class="bi bi-lock" aria-hidden="true"></i><span>@Localizer["CapabilityChatAfterText"]</span></li>
                    }
                    else if (!hasSummary)
                    {
                        <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i><span>@Localizer["CapabilityAskQuestions"]</span></li>
                        <li><i class="bi bi-arrow-right-circle" aria-hidden="true"></i><span>@Localizer["CapabilityGenerateSummary"]</span></li>
                    }
                    else
                    {
                        <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i><span>@Localizer["CapabilityReadSummary"]</span></li>
                        <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i><span>@Localizer["CapabilityAskQuestions"]</span></li>
                        <li><i class="bi bi-check-circle-fill" aria-hidden="true"></i><span>@Localizer["CapabilityExportResults"]</span></li>
                    }
                </ul>
            </div>

            <div class="section-card document-workspace-wide">
                <h2 class="h5">@Localizer["QuickOverview"]</h2>
                @if (hasSummary)
                {
                    <p class="mb-0">@Model.SummaryPreview</p>
                }
                else if (hasText)
                {
                    <div class="empty-state text-start">
                        <h3 class="h6">@Localizer["NoSummaryYet"]</h3>
                        <p>@Localizer["GenerateSummaryHint"]</p>
                        <form asp-action="GenerateSummary" asp-route-id="@document.Id" method="post" class="js-loading-form">
                            <button type="submit" class="btn btn-primary" data-loading-text="@Localizer["Generating"]">@Localizer["Generate Summary"]</button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="empty-state text-start">
                        <h3 class="h6">@Localizer["DocumentNotProcessedYet"]</h3>
                        <p>@Localizer["ExtractBeforeSummary"]</p>
                        <form asp-action="ExtractText" asp-route-id="@document.Id" method="post" class="js-loading-form">
                            <button type="submit" class="btn btn-primary" data-loading-text="@Localizer["Processing"]" @(fileExists ? "" : "disabled")>@Localizer["Extract Text"]</button>
                        </form>
                    </div>
                }
            </div>

            <div class="section-card document-workspace-wide">
                <h2 class="h5">@Localizer["NextStep"]</h2>
                @if (!hasText)
                {
                    <p>@Localizer["ExtractBeforeChat"]</p>
                    <form asp-action="ExtractText" asp-route-id="@document.Id" method="post" class="js-loading-form">
                        <button type="submit" class="btn btn-primary" data-loading-text="@Localizer["Processing"]" @(fileExists ? "" : "disabled")>@Localizer["Extract Text"]</button>
                    </form>
                }
                else if (!hasSummary)
                {
                    <p>@Localizer["ReadyForSummaryHint"]</p>
                    <div class="d-flex flex-wrap gap-2">
                        <form asp-action="GenerateSummary" asp-route-id="@document.Id" method="post" class="js-loading-form">
                            <button type="submit" class="btn btn-primary" data-loading-text="@Localizer["Generating"]">@Localizer["Generate Summary"]</button>
                        </form>
                        <a class="btn btn-outline-primary" asp-action="Details" asp-route-id="@document.Id" asp-route-tab="chat">@Localizer["AskAI"]</a>
                    </div>
                }
                else
                {
                    <p>@Localizer["ReadyToAskAIHint"]</p>
                    <a class="btn btn-primary" asp-action="Details" asp-route-id="@document.Id" asp-route-tab="chat">@Localizer["AskAIAboutDocument"]</a>
                }
            </div>
        </div>
    }
    else if (Model.IsSummaryActive)
    {
        <div class="section-card">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                <div>
                    <h2 class="h5 mb-1">@Localizer["FullSummary"]</h2>
                    <p class="text-muted mb-0">@Localizer["SummaryTabHint"]</p>
                </div>
                @if (hasSummary)
                {
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-sm btn-outline-primary"
                                data-copy-target="documentSummary"
                                data-copied-text="@Localizer["Copied"]"
                                data-copy-success-text="@Localizer["CopiedToClipboard"]"
                                data-copy-error-text="@Localizer["CopyFailed"]">@Localizer["Copy"]</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                data-export-target="documentSummary"
                                data-export-filename="document-summary"
                                data-export-success-text="@Localizer["ExportedTxt"]"
                                data-export-error-text="@Localizer["ExportFailed"]"
                                aria-label="@Localizer["DownloadTxt"]">@Localizer["ExportTxt"]</button>
                        <form asp-action="GenerateSummary" asp-route-id="@document.Id" method="post" class="js-loading-form">
                            <button type="submit" class="btn btn-sm btn-outline-primary" data-loading-text="@Localizer["Generating"]">@Localizer["RegenerateSummary"]</button>
                        </form>
                    </div>
                }
            </div>

            @if (hasSummary)
            {
                <div id="documentSummary" class="document-summary-body">@document.Summary</div>
            }
            else if (hasText)
            {
                <div class="empty-state text-start">
                    <h3 class="h6">@Localizer["NoSummaryYet"]</h3>
                    <p>@Localizer["GenerateSummaryHint"]</p>
                    <form asp-action="GenerateSummary" asp-route-id="@document.Id" method="post" class="js-loading-form">
                        <button type="submit" class="btn btn-primary" data-loading-text="@Localizer["Generating"]">@Localizer["Generate Summary"]</button>
                    </form>
                </div>
            }
            else
            {
                <div class="empty-state text-start">
                    <h3 class="h6">@Localizer["ExtractBeforeSummaryTitle"]</h3>
                    <p>@Localizer["ExtractBeforeSummary"]</p>
                    <form asp-action="ExtractText" asp-route-id="@document.Id" method="post" class="js-loading-form">
                        <button type="submit" class="btn btn-primary" data-loading-text="@Localizer["Processing"]" @(fileExists ? "" : "disabled")>@Localizer["Extract Text"]</button>
                    </form>
                </div>
            }
        </div>
    }
    else
    {
        <partial name="~/Views/DocumentChat/_ChatPanel.cshtml" model="chatModel" />
    }
</section>
