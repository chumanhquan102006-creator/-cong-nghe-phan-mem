@model AcademicAIAssistant.Models.Document
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = "Document Details";
    bool fileExists = ViewData["FileExists"] as bool? ?? false;
    string extractedPreview = Model.ExtractedText ?? string.Empty;
    if (extractedPreview.Length > 1500)
    {
        extractedPreview = extractedPreview.Substring(0, 1500) + "...";
    }
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Model.Title</h1>
            <p class="page-subtitle">@Model.OriginalFileName</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Index">@Localizer["Back to Documents"]</a>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="section-card h-100">
                <h2 class="h5">@Localizer["File Information"]</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">@Localizer["Original File"]</dt>
                    <dd class="col-sm-8">@Model.OriginalFileName</dd>

                    <dt class="col-sm-4">Stored file</dt>
                    <dd class="col-sm-8">@Model.StoredFileName</dd>

                    <dt class="col-sm-4">@Localizer["File Size"]</dt>
                    <dd class="col-sm-8">@((Model.FileSize / 1024.0 / 1024.0).ToString("0.00")) MB</dd>

                    <dt class="col-sm-4">Content type</dt>
                    <dd class="col-sm-8">@Model.ContentType</dd>

                    <dt class="col-sm-4">@Localizer["Uploaded At"]</dt>
                    <dd class="col-sm-8">@Model.UploadedAt.ToDisplayDateTime()</dd>

                    <dt class="col-sm-4">Page count</dt>
                    <dd class="col-sm-8">@(Model.PageCount == 0 ? "Not extracted" : Model.PageCount)</dd>

                    <dt class="col-sm-4">Word count</dt>
                    <dd class="col-sm-8">@(Model.WordCount == 0 ? "Not extracted" : Model.WordCount)</dd>

                    <dt class="col-sm-4">Extracted at</dt>
                    <dd class="col-sm-8">@Model.ExtractedAt.ToDisplayDateTime(Localizer["NotAvailable"].Value)</dd>

                    <dt class="col-sm-4">Summary generated at</dt>
                    <dd class="col-sm-8">@Model.SummaryGeneratedAt.ToDisplayDateTime(Localizer["NotAvailable"].Value)</dd>
                </dl>

                @if (fileExists)
                {
                    <a class="btn btn-primary mt-3" href="@Model.FilePath" target="_blank" rel="noopener">@Localizer["Open PDF"]</a>
                }
                else
                {
                    <div class="alert alert-warning mt-3 mb-0">
                        The PDF file no longer exists on the server.
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-5">
            <div class="section-card h-100">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                    <h2 class="h5 mb-0">@Localizer["Summary"]</h2>
                    @if (!string.IsNullOrWhiteSpace(Model.Summary))
                    {
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-outline-primary"
                                    data-copy-target="documentSummary"
                                    data-copied-text="@Localizer["Copied"]"
                                    data-copy-error-text="@Localizer["CopyFailed"]">@Localizer["Copy"]</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                    data-export-target="documentSummary"
                                    data-export-filename="document-summary"
                                    data-export-success-text="@Localizer["ExportedTxt"]"
                                    data-export-error-text="@Localizer["ExportFailed"]"
                                    aria-label="@Localizer["DownloadTxt"]">@Localizer["ExportTxt"]</button>
                        </div>
                    }
                </div>
                <p id="documentSummary" class="mb-0">
                    @(string.IsNullOrWhiteSpace(Model.Summary) ? "Summary has not been generated yet." : Model.Summary)
                </p>
            </div>
        </div>
    </div>

    <div class="section-card mt-3">
        <h2 class="h5">@Localizer["Extracted Text Preview"]</h2>
        @if (string.IsNullOrWhiteSpace(Model.ExtractedText))
        {
            <div class="empty-state">No extracted text yet.</div>
        }
        else
        {
            <div class="text-preview">@extractedPreview</div>
        }
    </div>

    <div class="d-flex flex-wrap gap-2 mt-3">
        <a class="btn btn-outline-primary" asp-controller="DocumentChat" asp-action="Index" asp-route-documentId="@Model.Id">@Localizer["Chat with PDF"]</a>

        <form asp-action="ExtractText" asp-route-id="@Model.Id" method="post" class="js-loading-form">
            <button type="submit" class="btn btn-primary" data-loading-text="@Localizer["Processing"]" @(fileExists ? "" : "disabled")>@Localizer["Extract Text"]</button>
        </form>

        <form asp-action="GenerateSummary" asp-route-id="@Model.Id" method="post" class="js-loading-form">
            <button type="submit" class="btn btn-success" data-loading-text="@Localizer["Generating"]">@Localizer["Generate Summary"]</button>
        </form>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
              class="js-confirm-form" data-confirm-message="@Localizer["ConfirmDeleteMessage"]">
            <button type="submit" class="btn btn-outline-danger">@Localizer["Delete"]</button>
        </form>
    </div>
</section>
