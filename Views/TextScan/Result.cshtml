@model AcademicAIAssistant.Models.TextScan
@using System.Globalization

@{
    bool isVi = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "vi";
    ViewData["Title"] = isVi ? "Kết quả quét văn bản" : "Text Scan Result";
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Model.Title</h1>
            <p class="page-subtitle">@(isVi ? "Kết quả kiểm tra độ tương đồng nội bộ." : "Internal similarity scan result.")</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary" asp-action="Index">@(isVi ? "Quét mới" : "New Scan")</a>
            <a class="btn btn-outline-secondary" asp-action="History">@(isVi ? "Lịch sử" : "History")</a>
        </div>
    </div>

    <div class="alert alert-info">
        @(isVi
            ? "Độ tương đồng không đồng nghĩa chắc chắn với đạo văn. Công cụ này chỉ phát hiện mức độ trùng lặp với dữ liệu nội bộ trong hệ thống."
            : "Similarity does not always mean plagiarism. This tool only detects text overlap with your internal database.")
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="stat-card">
                <h2 class="h6">@(isVi ? "Số từ" : "Word Count")</h2>
                <p class="display-6 mb-0">@Model.WordCount</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <h2 class="h6">@(isVi ? "Điểm tương đồng" : "Similarity Score")</h2>
                <p class="display-6 mb-0">@Model.OverallSimilarityScore.ToString("0.##")%</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <h2 class="h6">@(isVi ? "Mức rủi ro" : "Risk Level")</h2>
                <p class="mb-0"><span class="badge fs-6 @GetRiskBadge(Model.RiskLevel)">@GetRiskLabel(Model.RiskLevel, isVi)</span></p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <h2 class="h6">@(isVi ? "Thời gian" : "Created")</h2>
                <p class="mb-0">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</p>
            </div>
        </div>
    </div>

    <div class="section-card mb-3">
        <h2 class="h5">@(isVi ? "Gợi ý xử lý" : "Suggestions")</h2>
        <ul class="mb-0">
            @foreach (string suggestion in GetSuggestions(Model.RiskLevel, isVi))
            {
                <li>@suggestion</li>
            }
        </ul>
    </div>

    <div class="section-card mb-3">
        <h2 class="h5">@(isVi ? "Preview văn bản đầu vào" : "Input Text Preview")</h2>
        <div class="text-preview">@TrimForPreview(Model.InputText)</div>
    </div>

    <div class="section-card">
        <h2 class="h5">@(isVi ? "Đoạn tương đồng" : "Matches")</h2>

        @if (!Model.Matches.Any())
        {
            <div class="empty-state">
                <p>@(isVi ? "Không phát hiện độ tương đồng nội bộ đáng kể." : "No significant internal similarity found.")</p>
            </div>
        }
        else
        {
            <div class="vstack gap-3">
                @foreach (var match in Model.Matches.OrderByDescending(item => item.SimilarityScore))
                {
                    <div class="feedback-card">
                        <div class="d-flex flex-wrap justify-content-between gap-2 mb-2">
                            <div>
                                <span class="badge text-bg-secondary">@match.SourceType</span>
                                <strong>@match.SourceTitle</strong>
                            </div>
                            <span class="badge text-bg-danger">@match.SimilarityScore.ToString("0.##")%</span>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <h3 class="h6">@(isVi ? "Đoạn đầu vào" : "Input Segment")</h3>
                                <blockquote class="blockquote small text-preview">@match.InputSegment</blockquote>
                            </div>
                            <div class="col-md-6">
                                <h3 class="h6">@(isVi ? "Đoạn nguồn tương đồng" : "Matched Source Segment")</h3>
                                <blockquote class="blockquote small text-preview">@match.MatchedSegment</blockquote>
                            </div>
                        </div>
                        <small class="text-muted">@match.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                    </div>
                }
            </div>
        }
    </div>
</section>

@functions {
    private static string GetRiskBadge(string riskLevel)
    {
        return riskLevel switch
        {
            "High" => "text-bg-danger",
            "Medium" => "text-bg-warning",
            _ => "text-bg-success"
        };
    }

    private static string GetRiskLabel(string riskLevel, bool isVi)
    {
        if (!isVi)
        {
            return riskLevel;
        }

        return riskLevel switch
        {
            "High" => "Cao",
            "Medium" => "Trung bình",
            _ => "Thấp"
        };
    }

    private static List<string> GetSuggestions(string riskLevel, bool isVi)
    {
        if (riskLevel == "High")
        {
            return isVi
                ? new List<string> { "Viết lại đoạn bị trùng bằng cách diễn đạt của riêng bạn.", "Thêm trích dẫn nếu ý tưởng lấy từ nguồn tài liệu.", "Tránh sao chép nguyên văn các cụm dài." }
                : new List<string> { "Rewrite the matched section in your own words.", "Add citation if the idea comes from a source.", "Avoid copying long phrases directly." };
        }

        if (riskLevel == "Medium")
        {
            return isVi
                ? new List<string> { "Xem lại các đoạn tương đồng cẩn thận.", "Cân nhắc diễn đạt lại và thêm trích dẫn nếu cần." }
                : new List<string> { "Review the matched sections carefully.", "Consider paraphrasing and citing sources." };
        }

        return isVi
            ? new List<string> { "Không phát hiện rủi ro tương đồng nội bộ lớn." }
            : new List<string> { "No major internal similarity risk found." };
    }

    private static string TrimForPreview(string text)
    {
        string normalizedText = System.Text.RegularExpressions.Regex.Replace(text, @"\s+", " ").Trim();
        return normalizedText.Length <= 1500 ? normalizedText : normalizedText[..1500] + "...";
    }
}
