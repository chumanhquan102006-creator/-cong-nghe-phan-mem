@model List<AcademicAIAssistant.Models.TextScan>
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["Text Scan History"];
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Localizer["Text Scan History"]</h1>
            <p class="page-subtitle">@Localizer["Text Scan History subtitle"]</p>
        </div>
        <a class="btn btn-primary" asp-action="Index">@Localizer["StartTextScan"]</a>
    </div>

    @if (!Model.Any())
    {
        <partial name="_EmptyState" view-data='new ViewDataDictionary(ViewData)
        {
            ["IconClass"] = "bi bi-file-earmark-text",
            ["Title"] = Localizer["EmptyTextScansTitle"],
            ["Description"] = Localizer["EmptyTextScansDescription"],
            ["ActionText"] = Localizer["StartTextScan"],
            ["ActionController"] = "TextScan",
            ["ActionAction"] = "Index"
        }' />
    }
    else
    {
        <div class="section-card">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>@Localizer["Title"]</th>
                            <th>@Localizer["Words"]</th>
                            <th>@Localizer["Score"]</th>
                            <th>@Localizer["Risk"]</th>
                            <th>@Localizer["Created"]</th>
                            <th class="text-end">@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var scan in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@scan.Title</td>
                                <td>@scan.WordCount</td>
                                <td>@scan.OverallSimilarityScore.ToString("0.##")%</td>
                                <td><span class="badge @GetRiskBadge(scan.RiskLevel)">@GetRiskLabel(scan.RiskLevel)</span></td>
                                <td>@scan.CreatedAt.ToDisplayDateTime()</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Result" asp-route-id="@scan.Id">@Localizer["View Result"]</a>
                                    <form asp-action="Delete" asp-route-id="@scan.Id" method="post"
                                          class="d-inline js-confirm-form"
                                          data-confirm-delete
                                          data-confirm-message="@Localizer["ConfirmDeleteMessage"]">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@Localizer["Delete"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>

@functions {
    private static string GetRiskBadge(string riskLevel)
    {
        return riskLevel switch
        {
            "High" => "text-bg-danger",
            "Medium" => "text-bg-warning",
            _ => "text-bg-success"
        };
    }

    private string GetRiskLabel(string riskLevel)
    {
        return riskLevel switch
        {
            "High" => Localizer["High"],
            "Medium" => Localizer["Medium"],
            _ => Localizer["Low"]
        };
    }
}
