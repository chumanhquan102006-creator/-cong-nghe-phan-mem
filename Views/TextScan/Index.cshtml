@model AcademicAIAssistant.Models.ViewModels.TextScanInputViewModel
@inject IStringLocalizer<SharedResource> Localizer

@{
    bool isVi = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "vi";
    ViewData["Title"] = Localizer["Text Similarity Scan"];
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Localizer["Text Similarity Scan"]</h1>
            <p class="page-subtitle">@Localizer["Text Similarity Scan subtitle"]</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="History">@Localizer["History"]</a>
    </div>

    <div class="alert alert-info">
        @Localizer["Text Scan Info Notice"]
    </div>

    <form asp-action="Scan" method="post" class="section-card js-loading-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label">@Localizer["Title"]</label>
            <input asp-for="Title" class="form-control" placeholder="@Localizer["Text Scan Title Placeholder"]" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="InputText" class="form-label">@Localizer["Text to scan"]</label>
            <textarea asp-for="InputText" class="form-control" rows="16"
                      data-text-counter data-counter-target="textScanCounter"></textarea>
            <span asp-validation-for="InputText" class="text-danger"></span>
            <div class="d-flex flex-wrap justify-content-between gap-2 form-text">
                <span>@Localizer["Text Scan Minimum Words Help"]</span>
                <span id="textScanCounter" aria-live="polite">
                    <span data-word-count>0</span> @Localizer["Words"] -
                    <span data-character-count>0</span> @Localizer["Characters"]
                </span>
            </div>
        </div>

        <button type="submit" class="btn btn-primary" data-loading-text="@Localizer["Scanning"]">@Localizer["Scan Text"]</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
