@model AcademicAIAssistant.Models.User

@{
    ViewData["Title"] = "User Profile";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-dark text-white text-center py-4 rounded-top">
                    <h3 class="mb-0">Thông Tin Tài Khoản</h3>
                </div>
                <div class="card-body p-5">
                    <div class="row align-items-center">
                        
                        <!-- Avatar Placeholder Section (Yêu cầu mở rộng của Issue) -->
                        <div class="col-md-4 text-center mb-4 mb-md-0">
                            <div class="d-inline-flex align-items-center justify-content-center bg-secondary text-white rounded-circle font-weight-bold" 
                                 style="width: 120px; height: 120px; font-size: 3rem; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">
                                @(!string.IsNullOrEmpty(Model.FullName) ? Model.FullName.Substring(0, 1).ToUpper() : "U")
                            </div>
                            <h5 class="mt-3 text-muted">@Model.Role</h5>
                        </div>

                        <!-- Bảng hiển thị 4 thông tin cốt lõi theo tiêu chí nghiệm thu -->
                        <div class="col-md-8">
                            <table class="table table-borderless fs-5">
                                <tbody>
                                    <tr>
                                        <th scope="row" class="text-secondary pb-3" style="width: 40%">Họ và tên:</th>
                                        <td class="font-weight-bold pb-3 text-dark">@Model.FullName</td>
                                    </tr>
                                    <tr>
                                        <th scope="row" class="text-secondary pb-3">Email:</th>
                                        <td class="pb-3 text-dark">@Model.Email</td>
                                    </tr>
                                    <tr>
                                        <th scope="row" class="text-secondary pb-3">Vai trò:</th>
                                        <td class="pb-3">
                                            <span class="badge bg-info text-dark px-3 py-2 fs-6">@Model.Role</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th scope="row" class="text-secondary pb-3">Ngày tham gia:</th>
                                        <td class="pb-3 text-muted">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light text-end py-3 rounded-bottom">
                    <a href="@Url.Action("Index", "Dashboard")" class="btn btn-outline-secondary px-4">
                        Quay lại Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>