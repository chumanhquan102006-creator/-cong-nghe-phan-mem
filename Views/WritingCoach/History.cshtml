@model List<AcademicAIAssistant.Models.WritingCoachSession>
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["Writing Coach History"];
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Localizer["Writing Coach History"]</h1>
            <p class="page-subtitle">@Localizer["Writing Coach History subtitle"]</p>
        </div>
        <a class="btn btn-primary" asp-action="Index">@Localizer["OpenWritingCoach"]</a>
    </div>

    @if (!Model.Any())
    {
        <partial name="_EmptyState" view-data='new ViewDataDictionary(ViewData)
        {
            ["IconClass"] = "bi bi-lightbulb",
            ["Title"] = Localizer["EmptyWritingCoachTitle"],
            ["Description"] = Localizer["EmptyWritingCoachDescription"],
            ["ActionText"] = Localizer["OpenWritingCoach"],
            ["ActionController"] = "WritingCoach",
            ["ActionAction"] = "Index"
        }' />
    }
    else
    {
        <div class="section-card">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>@Localizer["Mode"]</th>
                            <th>@Localizer["Topic"]</th>
                            <th>@Localizer["Essay Type"]</th>
                            <th>@Localizer["Language"]</th>
                            <th>@Localizer["Created"]</th>
                            <th class="text-end">@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in Model)
                        {
                            <tr>
                                <td><span class="badge text-bg-primary status-badge">@session.Mode</span></td>
                                <td class="fw-semibold">@session.Topic</td>
                                <td>@session.EssayType</td>
                                <td>@(session.Language == "vi" ? Localizer["Vietnamese"] : Localizer["English"])</td>
                                <td>@session.CreatedAt.ToDisplayDateTime()</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@session.Id">@Localizer["View Details"]</a>
                                    <form asp-action="Delete" asp-route-id="@session.Id" method="post"
                                          class="d-inline js-confirm-form"
                                          data-confirm-delete
                                          data-confirm-message="@Localizer["ConfirmDeleteMessage"]">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@Localizer["Delete"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
