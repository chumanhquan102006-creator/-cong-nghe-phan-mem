@model AcademicAIAssistant.Models.ViewModels.WritingCoachViewModel
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["AI Writing Coach"];
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Localizer["AI Writing Coach"]</h1>
            <p class="page-subtitle">@Localizer["AI Writing Coach subtitle"]</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="History">@Localizer["History"]</a>
    </div>

    <div class="section-card">
        <form asp-action="Generate" method="post" class="js-loading-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Mode" class="form-label">@Localizer["Mode"]</label>
                    <select asp-for="Mode" class="form-select">
                        @foreach (var option in WritingCoachViewModel.ModeOptions)
                        {
                            <option value="@option.Key">@option.Value</option>
                        }
                    </select>
                    <span asp-validation-for="Mode" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Language" class="form-label">@Localizer["Response Language"]</label>
                    <select asp-for="Language" class="form-select">
                        @foreach (var option in WritingCoachViewModel.LanguageOptions)
                        {
                            <option value="@option.Key">@option.Value</option>
                        }
                    </select>
                </div>

                <div class="col-md-8">
                    <label asp-for="Topic" class="form-label">@Localizer["Topic"]</label>
                    <input asp-for="Topic" class="form-control" placeholder="@Localizer["WritingCoach_TopicPlaceholder"]" />
                    <span asp-validation-for="Topic" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="EssayType" class="form-label">@Localizer["Essay Type"]</label>
                    <select asp-for="EssayType" class="form-select">
                        @foreach (string option in WritingCoachViewModel.EssayTypeOptions)
                        {
                            <option value="@option">@option</option>
                        }
                    </select>
                </div>

                <div class="col-12">
                    <label asp-for="ThesisStatement" class="form-label">@Localizer["Thesis Statement / Main Claim"]</label>
                    <textarea asp-for="ThesisStatement" class="form-control" rows="3"
                              data-text-counter data-counter-target="thesisCounter"></textarea>
                    <span asp-validation-for="ThesisStatement" class="text-danger"></span>
                    <div id="thesisCounter" class="form-text text-end" aria-live="polite">
                        <span data-word-count>0</span> @Localizer["Words"] -
                        <span data-character-count>0</span> @Localizer["Characters"]
                    </div>
                </div>

                <div class="col-12">
                    <label asp-for="UserInput" class="form-label">@Localizer["Additional Instructions"]</label>
                    <textarea asp-for="UserInput" class="form-control" rows="5"
                              placeholder="@Localizer["Additional Instructions Placeholder"]"
                              data-text-counter data-counter-target="coachInputCounter"></textarea>
                    <div id="coachInputCounter" class="form-text text-end" aria-live="polite">
                        <span data-word-count>0</span> @Localizer["Words"] -
                        <span data-character-count>0</span> @Localizer["Characters"]
                    </div>
                </div>
            </div>

            <div class="alert alert-info mt-3">
                @Localizer["Writing Coach Notice"]
            </div>

            <button type="submit" class="btn btn-primary" data-loading-text="@Localizer["Generating"]">@Localizer["Generate"]</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
