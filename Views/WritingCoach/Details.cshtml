@model AcademicAIAssistant.Models.WritingCoachSession
@using System.Globalization

@{
    bool isVi = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "vi";
    bool hasResponse = !string.IsNullOrWhiteSpace(Model.AIResponse);
    ViewData["Title"] = isVi ? "Chi tiết trợ lý viết luận" : "Writing Coach Details";
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@(isVi ? "Chi tiết trợ lý viết luận" : "Writing Coach Details")</h1>
            <p class="page-subtitle">@Model.Topic</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="History">@(isVi ? "Về lịch sử" : "Back to History")</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="section-card">
                <h2 class="h5">@(isVi ? "Thông tin phiên" : "Session Info")</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-5">Mode</dt>
                    <dd class="col-sm-7"><span class="badge text-bg-primary status-badge">@Model.Mode</span></dd>

                    <dt class="col-sm-5">Topic</dt>
                    <dd class="col-sm-7">@Model.Topic</dd>

                    <dt class="col-sm-5">Essay Type</dt>
                    <dd class="col-sm-7">@Model.EssayType</dd>

                    <dt class="col-sm-5">Language</dt>
                    <dd class="col-sm-7">@(Model.Language == "vi" ? "Vietnamese" : "English")</dd>

                    <dt class="col-sm-5">Created</dt>
                    <dd class="col-sm-7">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                </dl>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ThesisStatement) || !string.IsNullOrWhiteSpace(Model.UserInput))
            {
                <div class="section-card mt-3">
                    <h2 class="h5">@(isVi ? "Input của bạn" : "Your Input")</h2>
                    @if (!string.IsNullOrWhiteSpace(Model.ThesisStatement))
                    {
                        <p class="fw-semibold mb-1">Thesis</p>
                        <p class="text-muted">@Model.ThesisStatement</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.UserInput))
                    {
                        <p class="fw-semibold mb-1">Instructions</p>
                        <p class="text-muted">@Model.UserInput</p>
                    }
                </div>
            }
        </div>

        <div class="col-lg-8">
            <div class="section-card">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                    <h2 class="h5 mb-0">@(isVi ? "Kết quả" : "Response")</h2>
                    <div class="d-flex flex-wrap gap-2">
                        <button id="copyResponseButton" type="button" class="btn btn-outline-primary btn-sm" @(hasResponse ? "" : "disabled")>
                            @(isVi ? "Copy" : "Copy Response")
                        </button>
                        <form asp-action="SendToWriting" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="btn btn-primary btn-sm" @(hasResponse ? "" : "disabled")>
                                @(isVi ? "Gửi sang Writing Studio" : "Send to Writing Studio")
                            </button>
                        </form>
                    </div>
                </div>

                @if (hasResponse)
                {
                    <textarea id="coachResponse" class="form-control text-preview" rows="22" readonly>@Model.AIResponse</textarea>
                }
                else
                {
                    <div class="empty-state">
                        <p>@(isVi ? "Chưa có nội dung phản hồi." : "No response content available.")</p>
                    </div>
                    <textarea id="coachResponse" class="d-none"></textarea>
                }
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <a class="btn btn-outline-secondary" asp-action="Index">@(isVi ? "Tạo mới" : "Back to Writing Coach")</a>
                <a class="btn btn-outline-secondary" asp-action="History">@(isVi ? "Lịch sử" : "Back to History")</a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Delete this writing coach session?');">
                    <button type="submit" class="btn btn-danger">@(isVi ? "Xóa" : "Delete")</button>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        const copyButton = document.getElementById('copyResponseButton');
        const responseText = document.getElementById('coachResponse');

        if (copyButton && responseText) {
            copyButton.addEventListener('click', async () => {
                const text = responseText.value;
                if (!text.trim()) {
                    alert('No response available to copy.');
                    return;
                }

                await navigator.clipboard.writeText(text);
                copyButton.textContent = 'Copied';
                setTimeout(() => copyButton.textContent = '@(isVi ? "Copy" : "Copy Response")', 1500);
            });
        }
    </script>
}
