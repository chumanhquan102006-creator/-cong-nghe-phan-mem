@model AcademicAIAssistant.Models.WritingCoachSession
@inject IStringLocalizer<SharedResource> Localizer

@{
    bool hasResponse = !string.IsNullOrWhiteSpace(Model.AIResponse);
    ViewData["Title"] = Localizer["Writing Coach Details"];
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Localizer["Writing Coach Details"]</h1>
            <p class="page-subtitle">@Model.Topic</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="History">@Localizer["Back to History"]</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="section-card">
                <h2 class="h5">@Localizer["Session Info"]</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-5">@Localizer["Mode"]</dt>
                    <dd class="col-sm-7"><span class="badge text-bg-primary status-badge">@Model.Mode</span></dd>

                    <dt class="col-sm-5">@Localizer["Topic"]</dt>
                    <dd class="col-sm-7">@Model.Topic</dd>

                    <dt class="col-sm-5">@Localizer["Essay Type"]</dt>
                    <dd class="col-sm-7">@Model.EssayType</dd>

                    <dt class="col-sm-5">@Localizer["Language"]</dt>
                    <dd class="col-sm-7">@(Model.Language == "vi" ? Localizer["Vietnamese"] : Localizer["English"])</dd>

                    <dt class="col-sm-5">@Localizer["Created"]</dt>
                    <dd class="col-sm-7">@Model.CreatedAt.ToDisplayDateTime()</dd>
                </dl>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ThesisStatement) || !string.IsNullOrWhiteSpace(Model.UserInput))
            {
                <div class="section-card mt-3">
                    <h2 class="h5">@Localizer["Your Input"]</h2>
                    @if (!string.IsNullOrWhiteSpace(Model.ThesisStatement))
                    {
                        <p class="fw-semibold mb-1">@Localizer["Thesis"]</p>
                        <p class="text-muted">@Model.ThesisStatement</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.UserInput))
                    {
                        <p class="fw-semibold mb-1">@Localizer["Instructions"]</p>
                        <p class="text-muted">@Model.UserInput</p>
                    }
                </div>
            }
        </div>

        <div class="col-lg-8">
            <div class="section-card">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                    <h2 class="h5 mb-0">@Localizer["Response"]</h2>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-outline-primary btn-sm"
                                data-copy-target="coachResponse"
                                data-copied-text="@Localizer["Copied"]"
                                data-copy-error-text="@Localizer["CopyFailed"]"
                                @(hasResponse ? "" : "disabled")>
                            @Localizer["Copy"]
                        </button>
                        <a class="btn btn-outline-secondary btn-sm @(hasResponse ? "" : "disabled")"
                           asp-action="ExportResponse"
                           asp-route-id="@Model.Id">@Localizer["ExportTxt"]</a>
                        <form asp-action="SendToWriting" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="btn btn-primary btn-sm" @(hasResponse ? "" : "disabled")>
                                @Localizer["Send to Writing Studio"]
                            </button>
                        </form>
                    </div>
                </div>

                @if (hasResponse)
                {
                    <textarea id="coachResponse" class="form-control text-preview" rows="22" readonly>@Model.AIResponse</textarea>
                }
                else
                {
                    <div class="empty-state">
                        <p>@Localizer["No response content available."]</p>
                    </div>
                    <textarea id="coachResponse" class="d-none"></textarea>
                }
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <a class="btn btn-outline-secondary" asp-action="Index">@Localizer["Back to Writing Coach"]</a>
                <a class="btn btn-outline-secondary" asp-action="History">@Localizer["Back to History"]</a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      class="js-confirm-form" data-confirm-message="@Localizer["ConfirmDeleteMessage"]">
                    <button type="submit" class="btn btn-danger">@Localizer["Delete"]</button>
                </form>
            </div>
        </div>
    </div>
</section>
