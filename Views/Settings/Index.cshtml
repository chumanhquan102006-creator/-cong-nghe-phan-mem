@model AcademicAIAssistant.Models.ViewModels.AISettingsViewModel

@{
    ViewData["Title"] = "Settings";
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">Settings</h1>
            <p class="page-subtitle">Configure personal AI mode for summary, writing feedback, and chat with PDF.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-controller="Dashboard" asp-action="Index">Back to Dashboard</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="section-card h-100">
                <h2 class="h5">Current AI Status</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-5">AI Mode</dt>
                    <dd class="col-sm-7">
                        @if (Model.IsEnabled)
                        {
                            <span class="badge text-bg-success status-badge">Enabled</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary status-badge">Disabled / Rule-based fallback</span>
                        }
                    </dd>

                    <dt class="col-sm-5">Provider</dt>
                    <dd class="col-sm-7">@Model.Provider</dd>

                    <dt class="col-sm-5">Model</dt>
                    <dd class="col-sm-7">@Model.ModelName</dd>

                    <dt class="col-sm-5">API Key</dt>
                    <dd class="col-sm-7">@Model.MaskedApiKey</dd>
                </dl>

                <div class="alert alert-warning mt-3 mb-0">
                    Your API key is stored for demo purposes. Do not use a production key in this student project unless encryption is implemented.
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="section-card">
                <h2 class="h5">AI Configuration</h2>

                <form asp-action="SaveAISettings" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Provider" class="form-label"></label>
                        <select asp-for="Provider" class="form-select">
                            @foreach (string provider in AISettingsViewModel.ProviderOptions)
                            {
                                <option value="@provider">@provider</option>
                            }
                        </select>
                        <span asp-validation-for="Provider" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ModelName" class="form-label"></label>
                        <input asp-for="ModelName" class="form-control" placeholder="gemini-1.5-flash" />
                        <span asp-validation-for="ModelName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ApiKey" class="form-label"></label>
                        <input asp-for="ApiKey" type="password" class="form-control" autocomplete="off" placeholder="Leave blank to keep existing API key" />
                        <span asp-validation-for="ApiKey" class="text-danger"></span>
                        <div class="form-text">The full API key is never displayed after saving.</div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input asp-for="IsEnabled" class="form-check-input" />
                        <label asp-for="IsEnabled" class="form-check-label">Enable AI mode</label>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-primary">Save Settings</button>
                    </div>
                </form>

                <form asp-action="TestAIConnection" method="post" class="mt-3">
                    <button type="submit" class="btn btn-outline-primary">Test AI Connection</button>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
