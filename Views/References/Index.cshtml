@model List<AcademicAIAssistant.Models.ReferenceItem>
@using AcademicAIAssistant.Models.ViewModels
@inject IStringLocalizer<SharedResource> Localizer

@{
    string search = ViewData["Search"] as string ?? string.Empty;
    string sourceType = ViewData["SourceType"] as string ?? string.Empty;
    ViewData["Title"] = Localizer["References"];
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Localizer["References"]</h1>
            <p class="page-subtitle">@Localizer["References subtitle"]</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-secondary" asp-action="Export">@Localizer["Export"]</a>
            <a class="btn btn-primary" asp-action="Create">@Localizer["AddReference"]</a>
        </div>
    </div>

    <form method="get" class="section-card mb-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label">@Localizer["Search"]</label>
                <input name="search" value="@search" class="form-control" placeholder="@Localizer["Title or author"]" />
            </div>
            <div class="col-md-4">
                <label class="form-label">@Localizer["Source Type"]</label>
                <select name="sourceType" class="form-select">
                    <option value="">@Localizer["All"]</option>
                    @foreach (string option in ReferenceItemFormViewModel.SourceTypeOptions)
                    {
                        <option value="@option" selected="@(sourceType == option)">@option</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary w-100">@Localizer["Filter"]</button>
            </div>
        </div>
    </form>

    @if (!Model.Any())
    {
        <partial name="_EmptyState" view-data='new ViewDataDictionary(ViewData)
        {
            ["IconClass"] = "bi bi-bookmark-plus",
            ["Title"] = Localizer["EmptyReferencesTitle"],
            ["Description"] = Localizer["EmptyReferencesDescription"],
            ["ActionText"] = Localizer["AddReference"],
            ["ActionController"] = "References",
            ["ActionAction"] = "Create"
        }' />
    }
    else
    {
        <div class="section-card">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>@Localizer["Title"]</th>
                            <th>@Localizer["Author"]</th>
                            <th>@Localizer["Year"]</th>
                            <th>@Localizer["Type"]</th>
                            <th>@Localizer["APA Preview"]</th>
                            <th class="text-end">@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Title</td>
                                <td>@item.Author</td>
                                <td>@item.Year</td>
                                <td><span class="badge text-bg-secondary">@item.SourceType</span></td>
                                <td class="small">@TrimPreview(item.ApaReference)</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id">@Localizer["Details"]</a>
                                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">@Localizer["Edit"]</a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                          class="d-inline js-confirm-form"
                                          data-confirm-message="@Localizer["ConfirmDeleteMessage"]">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">@Localizer["Delete"]</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>

@functions {
    private static string TrimPreview(string value)
    {
        return string.IsNullOrWhiteSpace(value) || value.Length <= 120 ? value : value[..120] + "...";
    }
}
