@model AcademicAIAssistant.Models.ViewModels.ReferenceItemFormViewModel
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["Edit Reference"];
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Localizer["Edit Reference"]</h1>
            <p class="page-subtitle">@Localizer["Edit Reference subtitle"]</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Index">@Localizer["Back to References"]</a>
    </div>

    <form asp-action="Edit" method="post" class="section-card js-loading-form">
        <partial name="_ReferenceForm" model="Model" />
        <button type="submit" class="btn btn-primary mt-3" data-loading-text="@Localizer["Generating"]">@Localizer["Update Reference"]</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
