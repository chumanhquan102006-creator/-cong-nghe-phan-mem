@model AcademicAIAssistant.Models.ReferenceItem
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["Reference Details"];
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Model.Title</h1>
            <p class="page-subtitle">@Model.SourceType - @Model.Author</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-secondary" asp-action="Index">@Localizer["Back to References"]</a>
            <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">@Localizer["Edit"]</a>
            <a class="btn btn-outline-secondary" asp-action="ExportText" asp-route-id="@Model.Id">@Localizer["ExportTxt"]</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="section-card">
                <h2 class="h5">@Localizer["Source Information"]</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-5">@Localizer["Type"]</dt>
                    <dd class="col-sm-7">@Model.SourceType</dd>
                    <dt class="col-sm-5">@Localizer["Author"]</dt>
                    <dd class="col-sm-7">@Model.Author</dd>
                    <dt class="col-sm-5">@Localizer["Year"]</dt>
                    <dd class="col-sm-7">@Model.Year</dd>
                    <dt class="col-sm-5">@Localizer["Journal / Publisher"]</dt>
                    <dd class="col-sm-7">@Model.JournalOrPublisher</dd>
                    <dt class="col-sm-5">@Localizer["Website"]</dt>
                    <dd class="col-sm-7">@Model.WebsiteName</dd>
                    <dt class="col-sm-5">URL</dt>
                    <dd class="col-sm-7 text-break">@Model.Url</dd>
                    <dt class="col-sm-5">DOI</dt>
                    <dd class="col-sm-7">@Model.Doi</dd>
                    <dt class="col-sm-5">@Localizer["Pages"]</dt>
                    <dd class="col-sm-7">@Model.Pages</dd>
                </dl>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Notes))
            {
                <div class="section-card mt-3">
                    <h2 class="h5">@Localizer["Notes"]</h2>
                    <p class="mb-0">@Model.Notes</p>
                </div>
            }
        </div>

        <div class="col-lg-8">
            <div class="section-card">
                <h2 class="h5">@Localizer["Citation Output"]</h2>
                <div class="vstack gap-3">
                    <partial name="_CopyBlock" model='new CopyBlockViewModel(Localizer["APA In-text Citation"].Value, Model.ApaInTextCitation, "apaInText")' />
                    <partial name="_CopyBlock" model='new CopyBlockViewModel(Localizer["APA Reference"].Value, Model.ApaReference, "apaReference")' />
                    <partial name="_CopyBlock" model='new CopyBlockViewModel(Localizer["MLA In-text Citation"].Value, Model.MlaInTextCitation, "mlaInText")' />
                    <partial name="_CopyBlock" model='new CopyBlockViewModel(Localizer["MLA Reference"].Value, Model.MlaReference, "mlaReference")' />
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <form asp-action="SendToWriting" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-primary">@Localizer["Send to Writing Studio"]</button>
                </form>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      class="js-confirm-form"
                      data-confirm-delete
                      data-confirm-message="@Localizer["ConfirmDeleteMessage"]">
                    <button type="submit" class="btn btn-danger">@Localizer["Delete"]</button>
                </form>
            </div>
        </div>
    </div>
</section>
