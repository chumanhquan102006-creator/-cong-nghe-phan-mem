@model List<AcademicAIAssistant.Models.ReferenceItem>
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["References_ExportTitle"];
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Localizer["References_ExportTitle"]</h1>
            <p class="page-subtitle">@Localizer["References_ExportSubtitle"]</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Index">@Localizer["Back to References"]</a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <p>@Localizer["References_ExportEmpty"]</p>
            <a class="btn btn-primary" asp-action="Create">@Localizer["Create Reference"]</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="section-card">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <h2 class="h5 mb-0">@Localizer["APA References"]</h2>
                        <div class="d-flex flex-wrap gap-2">
                            <button type="button" class="btn btn-sm btn-outline-primary"
                                    data-copy-target="apaExport"
                                    data-copied-text="@Localizer["Copied"]"
                                    data-copy-error-text="@Localizer["CopyFailed"]">@Localizer["Copy"]</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                    data-export-target="apaExport"
                                    data-export-filename="reference-result"
                                    data-export-success-text="@Localizer["ExportedTxt"]"
                                    data-export-error-text="@Localizer["ExportFailed"]"
                                    aria-label="@Localizer["DownloadTxt"]">@Localizer["ExportTxt"]</button>
                        </div>
                    </div>
                    <textarea id="apaExport" class="form-control text-preview" rows="20" readonly>@string.Join(Environment.NewLine + Environment.NewLine, Model.Select(item => item.ApaReference))</textarea>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="section-card">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <h2 class="h5 mb-0">@Localizer["MLA References"]</h2>
                        <div class="d-flex flex-wrap gap-2">
                            <button type="button" class="btn btn-sm btn-outline-primary"
                                    data-copy-target="mlaExport"
                                    data-copied-text="@Localizer["Copied"]"
                                    data-copy-error-text="@Localizer["CopyFailed"]">@Localizer["Copy"]</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                    data-export-target="mlaExport"
                                    data-export-filename="reference-result"
                                    data-export-success-text="@Localizer["ExportedTxt"]"
                                    data-export-error-text="@Localizer["ExportFailed"]"
                                    aria-label="@Localizer["DownloadTxt"]">@Localizer["ExportTxt"]</button>
                        </div>
                    </div>
                    <textarea id="mlaExport" class="form-control text-preview" rows="20" readonly>@string.Join(Environment.NewLine + Environment.NewLine, Model.Select(item => item.MlaReference))</textarea>
                </div>
            </div>
        </div>
    }
</section>
