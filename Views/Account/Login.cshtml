@model AcademicAIAssistant.Models.ViewModels.LoginViewModel
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = "Login";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<section class="row justify-content-center py-4">
    <div class="col-md-6 col-lg-5">
        <h1 class="h3 mb-3">@Localizer["Login"]</h1>

        <div class="alert alert-info">
            @Localizer["Login_SecurityNotice"]
        </div>

        <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post" class="border rounded p-4 bg-light">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-primary w-100">@Localizer["Login"]</button>
        </form>

        <p class="mt-3">
            @Localizer["Do Not Have An Account"]
            <a asp-controller="Account" asp-action="Register">@Localizer["Register"]</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
