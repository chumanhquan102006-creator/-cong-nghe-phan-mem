@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer
@inject IWebHostEnvironment Environment

@{
    string? currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    string? currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    bool isAuthenticated = User.Identity?.IsAuthenticated == true;
    bool isDashboardActive = currentController == "Dashboard";
    bool isDocumentsActive = currentController is "Documents" or "DocumentChat";
    bool isWritingActive = currentController is "Writing" or "WritingCoach" or "WritingStudio";
    bool isReferencesActive = currentController == "References";
    bool isToolsActive = currentController is "OCR" or "TextScan" or "Citation" or "Similarity" or "Graph";
    bool isUserActive = currentController is "Account" or "Settings" or "DevTools";
}

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Academic AI Assistant</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AcademicAIAssistant.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom app-navbar">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">Academic AI Assistant</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse justify-content-between">
                    <ul class="navbar-nav app-main-nav">
                        @if (isAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(isDashboardActive ? "active" : "")" asp-area="" asp-controller="Dashboard" asp-action="Index" aria-current="@(isDashboardActive ? "page" : null)">@Localizer["Dashboard"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(isDocumentsActive ? "active" : "")" asp-area="" asp-controller="Documents" asp-action="Index" aria-current="@(isDocumentsActive ? "page" : null)">@Localizer["Documents"]</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isWritingActive ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @Localizer["NavWriting"]
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item @(currentController == "Writing" && currentAction == "Index" ? "active" : "")" asp-controller="Writing" asp-action="Index">@Localizer["NavAnalyzeEssay"]</a></li>
                                    <li><a class="dropdown-item @(currentController == "WritingCoach" ? "active" : "")" asp-controller="WritingCoach" asp-action="Index">@Localizer["NavWritingCoach"]</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item @(currentController == "Writing" && currentAction == "History" ? "active" : "")" asp-controller="Writing" asp-action="History">@Localizer["NavWritingHistory"]</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isReferencesActive ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @Localizer["References"]
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item @(currentController == "References" && currentAction == "Index" ? "active" : "")" asp-controller="References" asp-action="Index">@Localizer["NavReferenceManager"]</a></li>
                                    <li><a class="dropdown-item @(currentController == "References" && currentAction == "Export" ? "active" : "")" asp-controller="References" asp-action="Export">@Localizer["NavReferenceExport"]</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isToolsActive ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @Localizer["NavTools"]
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item @(currentController == "OCR" ? "active" : "")" asp-controller="OCR" asp-action="Index">@Localizer["NavOCR"]</a></li>
                                    <li><a class="dropdown-item @(currentController == "TextScan" ? "active" : "")" asp-controller="TextScan" asp-action="Index">@Localizer["NavTextSimilarity"]</a></li>
                                    <li><a class="dropdown-item @(currentController == "Graph" ? "active" : "")" asp-controller="Graph" asp-action="Index">@Localizer["NavKnowledgeGraph"]</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Home" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">@Localizer["Home"]</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav app-account-nav">
                        @if (isAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isUserActive ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @User.Identity?.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item @(currentController == "Account" && currentAction == "Profile" ? "active" : "")" asp-controller="Account" asp-action="Profile">@Localizer["Profile"]</a></li>
                                    <li><a class="dropdown-item @(currentController == "Settings" ? "active" : "")" asp-controller="Settings" asp-action="Index">@Localizer["NavSettings"]</a></li>
                                    <li><a class="dropdown-item @(currentController == "Account" && currentAction == "ChangePassword" ? "active" : "")" asp-controller="Account" asp-action="ChangePassword">@Localizer["Change Password"]</a></li>
                                    @if (Environment.IsDevelopment())
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item @(currentController == "DevTools" ? "active" : "")" asp-controller="DevTools" asp-action="Index">@Localizer["DevTools_Nav"]</a></li>
                                    }
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item">@Localizer["Logout"]</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">@Localizer["Login"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">@Localizer["Register"]</a>
                            </li>
                        }
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @Localizer["Language"]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <form asp-controller="Localization" asp-action="SetLanguage" method="post">
                                        <input type="hidden" name="culture" value="en" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="dropdown-item">English</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-controller="Localization" asp-action="SetLanguage" method="post">
                                        <input type="hidden" name="culture" value="vi" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="dropdown-item">Tiếng Việt</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container app-shell">
        <main role="main" class="pb-3">
            <partial name="_Alerts" />
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted app-footer">
        <div class="container">
            &copy; 2026 - Academic AI Assistant
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
