@model AcademicAIAssistant.Models.SimilarityCheck
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = "Similarity Result";
}

<section class="py-4">
    <div class="page-header">
        <div>
            <h1 class="page-title">@Localizer["Similarity Result"]</h1>
            <p class="page-subtitle">@Model.Essay?.Title - Checked at @Model.CheckedAt.ToDisplayDateTime()</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <button type="button" class="btn btn-outline-secondary"
                    data-export-target="similarityResultContent"
                    data-export-filename="similarity-result"
                    data-export-success-text="@Localizer["ExportedTxt"]"
                    data-export-error-text="@Localizer["ExportFailed"]"
                    aria-label="@Localizer["DownloadTxt"]">@Localizer["ExportTxt"]</button>
            <a class="btn btn-outline-secondary" asp-controller="Writing" asp-action="Details" asp-route-id="@Model.EssayId">Back to Essay</a>
        </div>
    </div>

    <div id="similarityResultContent">
    <div class="row g-3 mb-3">
        <div class="col-md-3">
                <div class="stat-card">
                <h2 class="h6">@Localizer["Overall Score"]</h2>
                <p class="display-6 mb-0">@Model.OverallSimilarityScore.ToString("0.00")%</p>
            </div>
        </div>
        <div class="col-md-3">
                <div class="stat-card">
                <h2 class="h6">@Localizer["Status"]</h2>
                <p class="display-6 mb-0">@Model.Status</p>
            </div>
        </div>
        <div class="col-md-3">
                <div class="stat-card">
                <h2 class="h6">Documents Compared</h2>
                <p class="display-6 mb-0">@Model.TotalDocumentsCompared</p>
            </div>
        </div>
        <div class="col-md-3">
                <div class="stat-card">
                <h2 class="h6">Matches</h2>
                <p class="display-6 mb-0">@Model.TotalMatches</p>
            </div>
        </div>
    </div>

    @if (!Model.Matches.Any())
    {
        <div class="empty-state">No significant similarity found.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var match in Model.Matches.OrderByDescending(item => item.SimilarityScore))
            {
                var essaySegmentId = $"similarityEssaySegment_{match.Id}";
                var matchedTextId = $"similarityMatchedText_{match.Id}";

                <div class="col-12">
                    <div class="section-card">
                        <div class="d-flex justify-content-between gap-3 mb-2">
                            <h2 class="h6 mb-0">@(match.Document?.Title ?? "Unknown document")</h2>
                            <span class="badge text-bg-danger status-badge">@match.SimilarityScore.ToString("0.00")%</span>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                                    <strong>Essay Segment</strong>
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-copy-target="@essaySegmentId"
                                            data-copied-text="@Localizer["Copied"]"
                                            data-copy-success-text="@Localizer["CopiedToClipboard"]"
                                            data-copy-error-text="@Localizer["CopyFailed"]"
                                            aria-label="@Localizer["CopyToClipboard"]">
                                        @Localizer["Copy"]
                                    </button>
                                </div>
                                <blockquote id="@essaySegmentId" class="text-preview mt-2 mb-0">@match.EssaySegment</blockquote>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                                    <strong>Matched Text</strong>
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-copy-target="@matchedTextId"
                                            data-copied-text="@Localizer["Copied"]"
                                            data-copy-success-text="@Localizer["CopiedToClipboard"]"
                                            data-copy-error-text="@Localizer["CopyFailed"]"
                                            aria-label="@Localizer["CopyToClipboard"]">
                                        @Localizer["Copy"]
                                    </button>
                                </div>
                                <blockquote id="@matchedTextId" class="text-preview mt-2 mb-0">@match.MatchedText</blockquote>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    </div>
</section>
